{
  "name": "steel-lib",
  "version": "0.3.0",
  "description": "Engine для сравнения и подбора аналогов марок сталей по ГОСТ. Поиск похожих марок, сравнение химического состава и механических свойств.",
  "keywords": [
    "steel",
    "gost",
    "metallurgy",
    "similarity",
    "alloy",
    "стали",
    "гост",
    "металлургия"
  ],
  "homepage": "https://github.com/fishruff/steel-lib#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fishruff/steel-lib.git"
  },
  "bugs": {
    "url": "https://github.com/fishruff/steel-lib/issues"
  },
  "author": "fishruff <arsershoff@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./steels_base.json": "./dist/steels_base.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/steels_base.json dist/steels_base.json",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
